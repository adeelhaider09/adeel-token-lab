{%- liquid
  assign heading_tag = section.settings.heading_tag | default: 'h2'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --kik-adeel-copy-max: {{ section.settings.intro_width }}px;
    --kik-adeel-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --kik-adeel-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --kik-adeel-pad-top-desktop: {{ section.settings.padding_top }}px;
    --kik-adeel-pad-bottom-desktop: {{ section.settings.padding_bottom }}px;
  }
</style>

<section class="tw:relative tw:overflow-hidden tw:bg-bg-page">
  <div class="page-width tw:pt-[var(--kik-adeel-pad-top-mobile)] tw:pb-[var(--kik-adeel-pad-bottom-mobile)] tw:tablet:pt-[var(--kik-adeel-pad-top-desktop)] tw:tablet:pb-[var(--kik-adeel-pad-bottom-desktop)]">
    {%- if section.settings.kicker != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <div class="tw:mx-auto tw:flex tw:max-w-[var(--kik-adeel-copy-max)] tw:flex-col tw:items-center tw:gap-md tw:text-center">
        {%- if section.settings.kicker != blank -%}
          <span class="tw:inline-flex tw:items-center tw:rounded-pill tw:bg-bg-alt-1 tw:px-12 tw:py-8 tw:font-body tw:text-body-sm tw:font-semibold tw:uppercase tw:tracking-[0.08em] tw:text-text-secondary">
            {{ section.settings.kicker | escape }}
          </span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="tw:m-0 tw:text-balance tw:font-heading tw:text-h3 tw:font-bold tw:leading-[1.15] tw:tracking-[-0.02em] tw:text-text-primary tw:tablet:text-h2">
            {{ section.settings.heading | escape }}
          </{{ heading_tag }}>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="tw:m-0 tw:font-body tw:text-body-md tw:leading-body tw:text-text-tertiary">
            {{ section.settings.description | newline_to_br }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tw:mt-32 tw:grid tw:grid-cols-1 tw:gap-24 tw:tablet:grid-cols-2 {% if section.settings.desktop_columns == '2' %}tw:desktop:grid-cols-2{% elsif section.settings.desktop_columns == '3' %}tw:desktop:grid-cols-3{% else %}tw:desktop:grid-cols-4{% endif %}">
        {%- for block in section.blocks -%}
          <article class="tw:group tw:flex tw:h-full tw:flex-col tw:gap-16 tw:rounded-lg tw:border tw:border-border-subtle tw:bg-bg-surface tw:p-24 tw:shadow-[0_18px_45px_rgba(0,43,78,0.09)] tw:transition tw:duration-300 tw:hover:-translate-y-1" {{ block.shopify_attributes }}>
            <div class="tw:overflow-hidden tw:rounded-md tw:bg-bg-alt-inverse">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  loading="lazy"
                  class="tw:block tw:aspect-[16/10] tw:w-full tw:object-cover tw:transition-transform tw:duration-500 tw:group-hover:scale-[1.03]"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'tw:block tw:aspect-[16/10] tw:w-full' }}
              {%- endif -%}
            </div>

            <div class="tw:flex tw:flex-1 tw:flex-col tw:gap-8">
              {%- if block.settings.title != blank -%}
                <h3 class="tw:m-0 tw:font-heading tw:text-h6 tw:font-bold tw:leading-[1.3] tw:text-text-primary">
                  {{ block.settings.title | escape }}
                </h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="tw:m-0 tw:font-body tw:text-body-md tw:leading-body tw:text-text-tertiary">
                  {{ block.settings.text | newline_to_br }}
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "KIK Adeel Why Pococo",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Night Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Pococo Feels Better After Dark"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Use your Figma copy here. Keep it short and calm so the section stays visually balanced."
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ]
    },
    {
      "type": "range",
      "id": "intro_width",
      "label": "Intro width",
      "min": 420,
      "max": 760,
      "step": 20,
      "unit": "px",
      "default": 620
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Desktop top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Desktop bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Mobile top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Mobile bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add a short sentence from your Figma design."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "KIK Adeel Why Pococo",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Easy To Control Before Sleep",
            "text": "Set the mood with simple controls and a calmer pre-sleep routine."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Ambient Projection, Not Harsh Light",
            "text": "Fill the room with a softer glow that feels restful instead of distracting."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Disc-Based Scenes With More Depth",
            "text": "Detailed projected visuals feel richer and more atmospheric than flat light effects."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "A Softer Bedtime Atmosphere",
            "text": "Create a bedroom setup that feels quieter, warmer, and easier to unwind in."
          }
        }
      ]
    }
  ]
}
{% endschema %}